#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=dot-just/lib/lib.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/lib.sh"
trap - EXIT

declare -a TYPECHECK_ROOTS=()
declare -a PYREFLY_PATHS=()
declare -a DIALYZER_ROOTS=()
declare -a CHECK_CONFIG_LEVELS=()
declare -a CHECK_CONFIG_MESSAGES=()
declare -a CHECK_OPERATION_LEVELS=()
declare -a CHECK_OPERATION_PREFIXES=()
declare -a CHECK_OPERATION_COMMANDS=()
declare -a CHECK_OPERATION_CONFIGS=()
declare -a CHECK_OPERATION_TARGETS=()
RUN_DEFAULT_PYREFLY=0

package_has_script() {
  local root="$1"
  local script="$2"

  node -e '
    const fs = require("node:fs");
    const packagePath = process.argv[1];
    const script = process.argv[2];
    const pkg = JSON.parse(fs.readFileSync(packagePath, "utf8"));

    process.exit(pkg.scripts && pkg.scripts[script] ? 0 : 1);
  ' "$root/package.json" "$script"
}

add_typecheck_root() {
  local root="$1"

  if package_has_script "$root" typecheck; then
    TYPECHECK_ROOTS+=("$root")
  fi
}

add_pyrefly_path() {
  local path="$1"

  PYREFLY_PATHS+=("$(relative_path "$path")")
}

has_python_files() {
  local path="$1"
  local file

  while IFS= read -r -d '' file; do
    case "$file" in
    *.py | *.pyi)
      return 0
      ;;
    esac
  done < <(discover_project_files "$path")

  return 1
}

collect_python_path() {
  local path="$1"
  local file
  local matched=0

  if [[ -f "$path" ]]; then
    case "$path" in
    *.py | *.pyi)
      add_pyrefly_path "$path"
      return 0
      ;;
    esac

    return 1
  fi

  if [[ -d "$path" ]]; then
    while IFS= read -r -d '' file; do
      case "$file" in
      *.py | *.pyi)
        matched=1
        ;;
      esac
    done < <(discover_project_files "$path")

    if [[ "$matched" -eq 1 ]]; then
      add_pyrefly_path "$path"
      return 0
    fi
  fi

  return 1
}

collect_type_path() {
  local selector="$1"
  local path
  local app
  local root
  local matched_node=0
  local matched_python=0

  path="$(resolve_path "$selector")"

  [[ -e "$path" ]] || die "path does not exist: $path"

  if [[ "$path" == "$REPO_ROOT" ]]; then
    while read -r _app root; do
      add_typecheck_root "$root"
    done < <(node_apps)

    if has_python_files "$REPO_ROOT"; then
      RUN_DEFAULT_PYREFLY=1
    fi

    return
  fi

  while read -r app root; do
    if [[ "$path" == "$root" || "$path" == "$root/"* ]]; then
      matched_node=1
      add_typecheck_root "$root"
    fi
  done < <(node_apps)

  if collect_python_path "$path"; then
    matched_python=1
  fi

  if [[ "$matched_node" -eq 0 && "$matched_python" -eq 0 ]]; then
    printf "No typecheck target matched %s\n" "$(relative_path "$path")" >&2
  fi
}

add_dialyzer_root() {
  local root="$1"

  [[ -f "$root/mix.exs" ]] && DIALYZER_ROOTS+=("$root")
}

collect_dialyzer_path() {
  local selector="$1"
  local path
  local root

  path="$(resolve_path "$selector")"
  [[ -e "$path" ]] || die "path does not exist: $path"

  if [[ "$path" == "$REPO_ROOT" ]]; then
    while read -r _app root; do
      add_dialyzer_root "$root"
    done < <(elixir_roots)

    return
  fi

  if root="$(elixir_root_for_path "$path")"; then
    add_dialyzer_root "$root"
  else
    printf "No Dialyzer target matched %s\n" "$(relative_path "$path")" >&2
  fi
}

unique_typecheck_roots() {
  local root

  printf "%s\n" "${TYPECHECK_ROOTS[@]}" | awk '!seen[$0]++' | while IFS= read -r root; do
    [[ -n "$root" ]] && printf "%s\n" "$root"
  done
}

unique_pyrefly_paths() {
  local path

  printf "%s\n" "${PYREFLY_PATHS[@]}" | awk '!seen[$0]++' | while IFS= read -r path; do
    [[ -n "$path" ]] && printf "%s\n" "$path"
  done
}

unique_dialyzer_roots() {
  local root

  printf "%s\n" "${DIALYZER_ROOTS[@]}" | awk '!seen[$0]++' | while IFS= read -r root; do
    [[ -n "$root" ]] && printf "%s\n" "$root"
  done
}

record_check_config() {
  local level="$1"
  local message="$2"

  CHECK_CONFIG_LEVELS+=("$level")
  CHECK_CONFIG_MESSAGES+=("$message")
}

record_check_operation() {
  local level="$1"
  local prefix="$2"
  local command="$3"
  local config="$4"
  local target="$5"

  CHECK_OPERATION_LEVELS+=("$level")
  CHECK_OPERATION_PREFIXES+=("$prefix")
  CHECK_OPERATION_COMMANDS+=("$command")
  CHECK_OPERATION_CONFIGS+=("$config")
  CHECK_OPERATION_TARGETS+=("$target")
}

last_step_status() {
  local count
  local index

  count="${#JUST_STEP_STATUSES[@]}"
  [[ "$count" -gt 0 ]] || printf "0\n"
  [[ "$count" -gt 0 ]] || return 0

  index="$((count - 1))"
  printf "%s\n" "${JUST_STEP_STATUSES[$index]}"
}

collect_check_step() {
  local label="$1"
  local cwd="$2"
  local display_command="$3"
  local config="$4"
  local target="$5"
  local status
  local level

  shift 5

  JUST_STEP_DISPLAY_COMMAND="$display_command" collect_step "$label" "$cwd" "$@"
  status="$(last_step_status)"

  if [[ "$status" -eq 0 ]]; then
    level="info"
  else
    level="error"
  fi

  record_check_operation "$level" "" "$display_command" "$config" "$target"
}

pyrefly_config_display() {
  if [[ -f "$REPO_ROOT/pyrefly.toml" ]]; then
    printf "pyrefly.toml"
  elif [[ -f "$REPO_ROOT/pyproject.toml" ]] && grep -Eq '^[[:space:]]*\[tool\.pyrefly([.]|])' "$REPO_ROOT/pyproject.toml"; then
    printf "pyproject.toml"
  else
    printf "auto"
  fi
}

print_check_summary() {
  local index
  local prefix
  local total_configs="${#CHECK_CONFIG_LEVELS[@]}"
  local total_operations="${#CHECK_OPERATION_LEVELS[@]}"

  printf "\n== Summary ==\n\n"

  if [[ "$total_configs" -gt 0 ]]; then
    for ((index = 0; index < total_configs; index++)); do
      printf "[%s] %s\n" "${CHECK_CONFIG_LEVELS[$index]}" "${CHECK_CONFIG_MESSAGES[$index]}"
    done
  fi

  if [[ "$total_configs" -gt 0 && "$total_operations" -gt 0 ]]; then
    printf "\n"
  fi

  if [[ "$total_operations" -gt 0 ]]; then
    for ((index = 0; index < total_operations; index++)); do
      prefix="${CHECK_OPERATION_PREFIXES[$index]}"

      if [[ -n "$prefix" ]]; then
        printf "[%s] [%s] [%s] [%s] %s\n" \
          "${CHECK_OPERATION_LEVELS[$index]}" \
          "$prefix" \
          "${CHECK_OPERATION_COMMANDS[$index]}" \
          "${CHECK_OPERATION_CONFIGS[$index]}" \
          "${CHECK_OPERATION_TARGETS[$index]}"
      else
        printf "[%s] [%s] [%s] %s\n" \
          "${CHECK_OPERATION_LEVELS[$index]}" \
          "${CHECK_OPERATION_COMMANDS[$index]}" \
          "${CHECK_OPERATION_CONFIGS[$index]}" \
          "${CHECK_OPERATION_TARGETS[$index]}"
      fi
    done
  fi
}

check_types() {
  local path
  local root
  local pyrefly_config
  local pyrefly_target
  local saw_root=0
  local saw_pyrefly=0
  local -a pyrefly_paths=()

  if [[ "$#" -eq 0 ]]; then
    while read -r _app root; do
      add_typecheck_root "$root"
    done < <(node_apps)

    if has_python_files "$REPO_ROOT"; then
      RUN_DEFAULT_PYREFLY=1
    fi
  else
    for path in "$@"; do
      collect_type_path "$path"
    done
  fi

  while IFS= read -r root; do
    saw_root=1
    record_check_config "info" "configured typecheck: $(relative_path "$root/package.json")"
    collect_check_step "Typecheck" "$root" "pnpm run typecheck" "$(relative_path "$root/package.json")" "$(relative_path "$root")" pnpm run typecheck
  done < <(unique_typecheck_roots)

  if [[ "$RUN_DEFAULT_PYREFLY" -eq 1 ]]; then
    saw_pyrefly=1
    pyrefly_config="$(pyrefly_config_display)"
    record_check_config "info" "configured pyrefly: $pyrefly_config"
    collect_check_step "Pyrefly" "$REPO_ROOT" "pyrefly check" "$pyrefly_config" "." pyrefly check
  fi

  while IFS= read -r path; do
    pyrefly_paths+=("$path")
  done < <(unique_pyrefly_paths)

  if [[ "${#pyrefly_paths[@]}" -gt 0 ]]; then
    saw_pyrefly=1
    pyrefly_config="$(pyrefly_config_display)"
    pyrefly_target="$(printf "%s\n" "${pyrefly_paths[@]}" | paste -sd ' ' -)"
    record_check_config "info" "configured pyrefly: $pyrefly_config"
    collect_check_step "Pyrefly" "$REPO_ROOT" "$(command_string pyrefly check "${pyrefly_paths[@]}")" "$pyrefly_config" "$pyrefly_target" pyrefly check "${pyrefly_paths[@]}"
  fi

  if [[ "$saw_root" -eq 1 || "$saw_pyrefly" -eq 1 ]]; then
    print_check_summary
    fail_if_steps_failed
  else
    printf "No type checks selected.\n"
  fi
}

check_dialyzer() {
  local path
  local root
  local saw_root=0

  if [[ "$#" -eq 0 ]]; then
    while read -r _app root; do
      add_dialyzer_root "$root"
    done < <(elixir_roots)
  else
    for path in "$@"; do
      collect_dialyzer_path "$path"
    done
  fi

  while IFS= read -r root; do
    saw_root=1
    require_command mix
    record_check_config "info" "configured dialyzer: $(relative_path "$root/mix.exs")"
    collect_check_step "Dialyzer" "$root" "mix dialyzer --format short" "$(relative_path "$root/mix.exs")" "$(relative_path "$root")" mix dialyzer --format short
  done < <(unique_dialyzer_roots)

  if [[ "$saw_root" -eq 1 ]]; then
    print_check_summary
    fail_if_steps_failed
  else
    printf "No Dialyzer checks selected.\n"
  fi
}

check_knip() {
  [[ "$#" -eq 0 ]] || die "just check knip does not accept paths"

  collect_check_step "Knip" "$REPO_ROOT" "pnpm exec knip" "knip.json" "." pnpm exec knip
  print_check_summary
  fail_if_steps_failed
}

main() {
  cd "$REPO_ROOT"

  case "${1:-}" in
  types)
    shift
    check_types "$@"
    ;;
  dialyzer)
    shift
    check_dialyzer "$@"
    ;;
  knip)
    shift
    check_knip "$@"
    ;;
  *)
    die "unknown check target: ${1:-}; use 'just check types [PATH...]', 'just check dialyzer [PATH...]', or 'just check knip'"
    ;;
  esac
}

main "$@"
