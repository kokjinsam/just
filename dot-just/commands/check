#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=dot-just/lib/lib.sh
source "$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)/lib/lib.sh"
trap - EXIT

declare -a CHECK_FILES=()
declare -a OPENAPI_FILES=()
declare -a TYPECHECK_ROOTS=()
declare -a CHECK_CONFIG_LEVELS=()
declare -a CHECK_CONFIG_MESSAGES=()
declare -a CHECK_OPERATION_LEVELS=()
declare -a CHECK_OPERATION_PREFIXES=()
declare -a CHECK_OPERATION_COMMANDS=()
declare -a CHECK_OPERATION_CONFIGS=()
declare -a CHECK_OPERATION_TARGETS=()

add_file() {
  local file="$1"

  case "$file" in
  *.tla | *.cfg | *.als)
    CHECK_FILES+=("$file")
    ;;
  *.json | *.yaml | *.yml)
    if is_openapi_file "$file"; then
      OPENAPI_FILES+=("$file")
    fi
    ;;
  esac
}

is_openapi_file() {
  local file="$1"

  grep -Eq '(^[[:space:]]*(openapi|swagger)[[:space:]]*:)|("[[:space:]]*(openapi|swagger)[[:space:]]*"[[:space:]]*:)' "$file"
}

collect_path() {
  local path

  path="$(resolve_path "$1")"

  if [[ -d "$path" ]]; then
    while IFS= read -r -d '' file; do
      add_file "$file"
    done < <(discover_project_files "$path")
  elif [[ -f "$path" ]]; then
    add_file "$path"
  else
    die "path does not exist: $path"
  fi
}

unique_files() {
  local file

  [[ "${#CHECK_FILES[@]}" -gt 0 ]] || return 0

  printf "%s\n" "${CHECK_FILES[@]}" | awk '!seen[$0]++' | while IFS= read -r file; do
    [[ -n "$file" ]] && printf "%s\n" "$file"
  done
}

unique_openapi_files() {
  local file

  [[ "${#OPENAPI_FILES[@]}" -gt 0 ]] || return 0

  printf "%s\n" "${OPENAPI_FILES[@]}" | awk '!seen[$0]++' | while IFS= read -r file; do
    [[ -n "$file" ]] && printf "%s\n" "$file"
  done
}

cfg_has_selected_tla_module() {
  local cfg="$1"
  local tla="${cfg%.cfg}.tla"
  local file

  [[ "${#CHECK_FILES[@]}" -gt 0 ]] || return 1

  for file in "${CHECK_FILES[@]}"; do
    if [[ "$file" == "$tla" ]]; then
      return 0
    fi
  done

  return 1
}

package_has_script() {
  local root="$1"
  local script="$2"

  node -e '
    const fs = require("node:fs");
    const packagePath = process.argv[1];
    const script = process.argv[2];
    const pkg = JSON.parse(fs.readFileSync(packagePath, "utf8"));

    process.exit(pkg.scripts && pkg.scripts[script] ? 0 : 1);
  ' "$root/package.json" "$script"
}

add_typecheck_root() {
  local root="$1"

  if package_has_script "$root" typecheck; then
    TYPECHECK_ROOTS+=("$root")
  fi
}

collect_type_path() {
  local selector="$1"
  local path
  local app
  local root
  local matched=0

  path="$(resolve_path "$selector")"

  [[ -e "$path" ]] || die "path does not exist: $path"

  if [[ "$path" == "$REPO_ROOT" ]]; then
    while read -r _app root; do
      add_typecheck_root "$root"
    done < <(node_apps)
    return
  fi

  while read -r app root; do
    if [[ "$path" == "$root" || "$path" == "$root/"* ]]; then
      matched=1
      add_typecheck_root "$root"
    fi
  done < <(node_apps)

  if [[ "$matched" -eq 0 ]]; then
    printf "No TypeScript app matched %s\n" "$(relative_path "$path")" >&2
  fi
}

unique_typecheck_roots() {
  local root

  printf "%s\n" "${TYPECHECK_ROOTS[@]}" | awk '!seen[$0]++' | while IFS= read -r root; do
    [[ -n "$root" ]] && printf "%s\n" "$root"
  done
}

record_check_config() {
  local level="$1"
  local message="$2"

  CHECK_CONFIG_LEVELS+=("$level")
  CHECK_CONFIG_MESSAGES+=("$message")
}

record_check_operation() {
  local level="$1"
  local prefix="$2"
  local command="$3"
  local config="$4"
  local target="$5"

  CHECK_OPERATION_LEVELS+=("$level")
  CHECK_OPERATION_PREFIXES+=("$prefix")
  CHECK_OPERATION_COMMANDS+=("$command")
  CHECK_OPERATION_CONFIGS+=("$config")
  CHECK_OPERATION_TARGETS+=("$target")
}

last_step_status() {
  local count
  local index

  count="${#JUST_STEP_STATUSES[@]}"
  [[ "$count" -gt 0 ]] || printf "0\n"
  [[ "$count" -gt 0 ]] || return 0

  index="$((count - 1))"
  printf "%s\n" "${JUST_STEP_STATUSES[$index]}"
}

collect_check_step() {
  local label="$1"
  local cwd="$2"
  local display_command="$3"
  local config="$4"
  local target="$5"
  local status
  local level

  shift 5

  JUST_STEP_DISPLAY_COMMAND="$display_command" collect_step "$label" "$cwd" "$@"
  status="$(last_step_status)"

  if [[ "$status" -eq 0 ]]; then
    level="info"
  else
    level="error"
  fi

  record_check_operation "$level" "" "$display_command" "$config" "$target"
}

print_check_summary() {
  local index
  local prefix
  local total_configs="${#CHECK_CONFIG_LEVELS[@]}"
  local total_operations="${#CHECK_OPERATION_LEVELS[@]}"

  printf "\n== Summary ==\n\n"

  if [[ "$total_configs" -gt 0 ]]; then
    for ((index = 0; index < total_configs; index++)); do
      printf "[%s] %s\n" "${CHECK_CONFIG_LEVELS[$index]}" "${CHECK_CONFIG_MESSAGES[$index]}"
    done
  fi

  if [[ "$total_configs" -gt 0 && "$total_operations" -gt 0 ]]; then
    printf "\n"
  fi

  if [[ "$total_operations" -gt 0 ]]; then
    for ((index = 0; index < total_operations; index++)); do
      prefix="${CHECK_OPERATION_PREFIXES[$index]}"

      if [[ -n "$prefix" ]]; then
        printf "[%s] [%s] [%s] [%s] %s\n" \
          "${CHECK_OPERATION_LEVELS[$index]}" \
          "$prefix" \
          "${CHECK_OPERATION_COMMANDS[$index]}" \
          "${CHECK_OPERATION_CONFIGS[$index]}" \
          "${CHECK_OPERATION_TARGETS[$index]}"
      else
        printf "[%s] [%s] [%s] %s\n" \
          "${CHECK_OPERATION_LEVELS[$index]}" \
          "${CHECK_OPERATION_COMMANDS[$index]}" \
          "${CHECK_OPERATION_CONFIGS[$index]}" \
          "${CHECK_OPERATION_TARGETS[$index]}"
      fi
    done
  fi
}

require_tool_command() {
  local command="$1"
  local plugin="$2"

  command -v "$command" >/dev/null 2>&1 ||
    die "missing required command: $command; run 'asdf install' after adding the '$plugin' asdf plugin"
}

check_tla_module() {
  local file="$1"
  local display_command
  local relative_file

  require_tool_command sany tlaplus
  relative_file="$(relative_path "$file")"
  display_command="$(command_string sany "$relative_file")"
  collect_check_step "TLA SANY" "$REPO_ROOT" "$display_command" "tlaplus" "$relative_file" sany "$relative_file"
}

check_tla_model() {
  local cfg="$1"
  local tla="${cfg%.cfg}.tla"
  local display_command
  local relative_cfg
  local relative_tla

  [[ -f "$tla" ]] || die "cannot find TLA module for config: $cfg"

  require_tool_command tlc tlaplus
  relative_cfg="$(relative_path "$cfg")"
  relative_tla="$(relative_path "$tla")"
  display_command="$(command_string tlc -config "$relative_cfg" "$relative_tla")"
  collect_check_step "TLA TLC" "$REPO_ROOT" "$display_command" "tlaplus" "$relative_cfg" tlc -config "$relative_cfg" "$relative_tla"
}

check_alloy_model() {
  local file="$1"
  local display_command
  local relative_file

  require_tool_command alloy alloy
  relative_file="$(relative_path "$file")"
  display_command="$(command_string alloy commands "$relative_file")"
  collect_check_step "Alloy" "$REPO_ROOT" "$display_command" "alloy" "$relative_file" alloy commands "$relative_file"
}

collect_default_specs() {
  local path
  local saw_path=0

  for path in "$REPO_ROOT/docs" "$REPO_ROOT/openapi"; do
    if [[ -d "$path" ]]; then
      saw_path=1
      collect_path "$path"
    fi
  done

  [[ "$saw_path" -eq 1 ]] || die "docs or openapi directory does not exist"
}

check_openapi_spec() {
  local file="$1"
  local display_command

  require_command vacuum
  display_command="$(command_string vacuum lint "$(relative_path "$file")")"
  collect_check_step "OpenAPI" "$REPO_ROOT" "$display_command" "openapi" "$(relative_path "$file")" vacuum lint "$file"
}

check_specs() {
  local path
  local file
  local saw_file=0

  if [[ "$#" -eq 0 ]]; then
    collect_default_specs
  else
    for path in "$@"; do
      collect_path "$path"
    done
  fi

  if [[ "${#CHECK_FILES[@]}" -eq 0 && "${#OPENAPI_FILES[@]}" -eq 0 ]]; then
    printf "No .tla, .cfg, .als, or OpenAPI files found.\n"
    return
  fi

  while IFS= read -r file; do
    saw_file=1

    case "$file" in
    *.tla)
      check_tla_module "$file"

      if [[ -f "${file%.tla}.cfg" ]]; then
        check_tla_model "${file%.tla}.cfg"
      fi
      ;;
    *.cfg)
      if cfg_has_selected_tla_module "$file"; then
        continue
      fi

      check_tla_model "$file"
      ;;
    *.als)
      check_alloy_model "$file"
      ;;
    esac
  done < <(unique_files)

  while IFS= read -r file; do
    saw_file=1
    check_openapi_spec "$file"
  done < <(unique_openapi_files)

  if [[ "$saw_file" -eq 1 ]]; then
    print_check_summary
    fail_if_steps_failed
  else
    printf "No .tla, .cfg, .als, or OpenAPI files found.\n"
  fi
}

check_types() {
  local path
  local root
  local saw_root=0

  if [[ "$#" -eq 0 ]]; then
    while read -r _app root; do
      add_typecheck_root "$root"
    done < <(node_apps)
  else
    for path in "$@"; do
      collect_type_path "$path"
    done
  fi

  while IFS= read -r root; do
    saw_root=1
    record_check_config "info" "configured typecheck: $(relative_path "$root/package.json")"
    collect_check_step "Typecheck" "$root" "pnpm run typecheck" "$(relative_path "$root/package.json")" "$(relative_path "$root")" pnpm run typecheck
  done < <(unique_typecheck_roots)

  if [[ "$saw_root" -eq 1 ]]; then
    print_check_summary
    fail_if_steps_failed
  else
    printf "No TypeScript checks selected.\n"
  fi
}

check_knip() {
  [[ "$#" -eq 0 ]] || die "just check knip does not accept paths"

  collect_check_step "Knip" "$REPO_ROOT" "pnpm exec knip" "knip.json" "." pnpm exec knip
  print_check_summary
  fail_if_steps_failed
}

main() {
  cd "$REPO_ROOT"

  case "${1:-}" in
  specs)
    shift
    check_specs "$@"
    ;;
  types)
    shift
    check_types "$@"
    ;;
  knip)
    shift
    check_knip "$@"
    ;;
  *)
    die "unknown check target: ${1:-}; use 'just check specs [PATH...]', 'just check types [PATH...]', or 'just check knip'"
    ;;
  esac
}

main "$@"
